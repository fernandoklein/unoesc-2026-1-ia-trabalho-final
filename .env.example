# Copie este arquivo para .env e preencha com sua chave do Google AI Studio
# (https://aistudio.google.com/app/apikey).
GEMINI_API_KEY=
# Opcional: modelo do Gemini (padrão: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite
# Opcional: URL do backend usada pelo frontend (padrão: http://localhost:8000)
BACKEND_URL=http://localhost:8000
